<odoo>

        <record id="sale_order_form_custom_field" model="ir.ui.view">

            <field name="name">sale.order.form.custom.field</field>

            <field name="model">sale.order</field>

            <field name="inherit_id" ref="sale.view_order_form"/>

            <field name="arch" type="xml"> 

                <xpath expr="//sheet" position="inside">

                    <group>

                        <field name="responsible_for_issuing"/>

                        <field name="new_field" readonly="state != 'draft'" invisible="state == 'sale'"/>

                    </group>

                </xpath>

            </field>
            
        </record>

</odoo>